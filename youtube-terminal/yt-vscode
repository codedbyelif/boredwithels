#!/bin/bash
FPS_ENV="${YTV_FPS:-}"
FPS="${FPS_ENV:-5}"
WIDTH_ENV="${YTV_WIDTH:-}"
HEIGHT_ENV="${YTV_HEIGHT_ROWS:-}"
MAXH="${YTV_HEIGHT:-480}"
PIXEL="${YTV_PIXEL:-auto}"
COLORS="${YTV_COLORS:-240}"

MODE=symbols
case "$PIXEL" in
  1) MODE=iip ;;
  0) MODE=symbols ;;
  *) if [ -n "${KITTY_WINDOW_ID:-}" ] || [ "${TERM:-}" = "xterm-kitty" ]; then
         MODE=kitty
     elif [ "${TERM_PROGRAM:-}" = "WezTerm" ]; then
         MODE=kitty
     elif [ "${TERM_PROGRAM:-}" = "iTerm.app" ]; then
         MODE=iip
     fi ;;
esac
EXT=png; [ "$MODE" = iip ] && EXT=jpg
[ "$MODE" = symbols ] && [ -z "$FPS_ENV" ] && FPS=4

set -uo pipefail
export PATH="$HOME/.local/bin:/opt/homebrew/bin:$PATH"

LOG=/tmp/yt-vscode.log
: > "$LOG"
logd(){ echo "$(date '+%H:%M:%S') $*" >> "$LOG"; }
logd "BAŞLADI  pid=$$  arg=[$*]  tty_stdin=$([ -t 0 ] && echo evet || echo hayır)"

[ $# -eq 0 ] && { echo "Kullanım: yt-vscode \"arama veya URL\""; exit 1; }
arg="$*"
case "$arg" in http*) page="$arg" ;; *) page="ytsearch1:$arg" ;; esac

TMPD=$(mktemp -d)
SOCK="/tmp/ytv_$$.sock"; rm -f "$SOCK"
AUDIO_PID=""; FFMPEG_PID=""

ipc(){ printf '%s\n' "$1" | nc -U "$SOCK" 2>/dev/null >/dev/null; }

cleanup() {
    ipc '{"command":["quit"]}'
    [ -n "$AUDIO_PID" ]  && kill "$AUDIO_PID"  2>/dev/null
    [ -n "$FFMPEG_PID" ] && kill "$FFMPEG_PID" 2>/dev/null
    pkill -P $$ ffmpeg 2>/dev/null
    rm -rf "$TMPD"; rm -f "$SOCK"
    printf '\033[0m\033[?25h\033[?1049l'; tput cnorm 2>/dev/null
}
trap cleanup EXIT INT TERM

echo "youtube-terminal · codedbyelif"
echo "Çözümleniyor: $arg"

COLS=$(tput cols 2>/dev/null || echo 80); ROWS=$(tput lines 2>/dev/null || echo 24)
WIDTH="${WIDTH_ENV:-$((COLS-2))}"
[ "$WIDTH" -gt $((COLS-2)) ] && WIDTH=$((COLS-2))
[ "$MODE" = symbols ] && [ -z "$WIDTH_ENV" ] && [ "$WIDTH" -gt 130 ] && WIDTH=130
HEIGHT="${HEIGHT_ENV:-$(awk "BEGIN{printf \"%d\", ${WIDTH}/3.5}")}"
if [ "$HEIGHT" -gt $((ROWS-3)) ]; then
    HEIGHT=$((ROWS-3))
    [ -z "$WIDTH_ENV" ] && { W2=$(awk "BEGIN{printf \"%d\", ${HEIGHT}*3.5}"); [ "$W2" -lt "$WIDTH" ] && WIDTH=$W2; }
fi

case "$MODE" in
  kitty) SRC_H="$MAXH" ;;
  iip)   SRC_H=360 ;;
  *)     NEED_PX=$((WIDTH*2))
         if [ "$NEED_PX" -le 400 ]; then SRC_H=240; else SRC_H=360; fi ;;
esac
[ "$SRC_H" -gt "$MAXH" ] && SRC_H="$MAXH"
URLS=$(yt-dlp --print urls \
       -f "bv[height<=${SRC_H}][vcodec^=avc]+ba[ext=m4a]/bv[height<=${SRC_H}]+ba[ext=m4a]/bv[height<=${MAXH}][ext=mp4]+ba[ext=m4a]/bv[height<=${MAXH}]+ba/b[height<=${MAXH}]" \
       "$page" 2>/dev/null)
VIDEO_URL=$(printf '%s\n' "$URLS" | sed -n 1p)
AUDIO_URL=$(printf '%s\n' "$URLS" | sed -n 2p)
[ -z "$AUDIO_URL" ] && AUDIO_URL="$VIDEO_URL"
STREAM="$VIDEO_URL"
logd "URL çözüldü  mod=$MODE kaynak=${SRC_H}p renk=$COLORS fps=$FPS  video=$(echo "$VIDEO_URL" | grep -oE 'manifest|videoplayback' | head -1)/$(echo "$VIDEO_URL" | grep -o 'itag=[0-9]*' | head -1)  ses=$(echo "$AUDIO_URL" | grep -o 'itag=[0-9]*' | head -1)"
[ -z "$STREAM" ] && { logd "HATA: URL çözülemedi"; echo "Çözümlenemedi. Dene:  brew upgrade yt-dlp"; exit 1; }

if [ "$MODE" = kitty ]; then
    logd "kitty modu: mpv --vo=kitty'ye devrediliyor"
    trap - EXIT INT TERM; rm -rf "$TMPD" "$SOCK"
    exec mpv --vo=kitty --really-quiet "$VIDEO_URL" --audio-file="$AUDIO_URL"
fi

echo "Başlıyor...  (çıkış: Ctrl+C)"; sleep 1

printf '\033[?1049h\033[?25l\033[2J'

mpv --no-video --no-config --input-ipc-server="$SOCK" --really-quiet "$AUDIO_URL" >/dev/null 2>&1 &
AUDIO_PID=$!
for i in $(seq 1 60); do [ -S "$SOCK" ] && break; sleep 0.1; done
if kill -0 "$AUDIO_PID" 2>/dev/null; then
    logd "mpv ses motoru ayakta  pid=$AUDIO_PID  soket=$([ -S "$SOCK" ] && echo açık || echo YOK)"
else
    logd "HATA: mpv ses motoru başlatılamadı, çıkılıyor"
    printf '\033[?1049l'; echo "Ses motoru (mpv) başlatılamadı. Log: /tmp/yt-vscode.log"; exit 1
fi

FRAME_BASE=0
start_ffmpeg() {
    local pos="${1:-0}"
    [ -n "$FFMPEG_PID" ] && kill "$FFMPEG_PID" 2>/dev/null
    pkill -P $$ ffmpeg 2>/dev/null
    rm -f "$TMPD"/g*_f*.png "$TMPD"/g*_f*.jpg 2>/dev/null
    FRAME_BASE=$((FRAME_BASE+1))
    if [ "$MODE" = iip ]; then
        ffmpeg -loglevel error \
               -reconnect 1 -reconnect_streamed 1 -reconnect_delay_max 2 \
               -ss "$pos" -re -i "$STREAM" \
               -vf "fps=${FPS}" -q:v 4 \
               "$TMPD/g${FRAME_BASE}_f%06d.jpg" >/dev/null 2>&1 &
    else
        ffmpeg -loglevel error \
               -reconnect 1 -reconnect_streamed 1 -reconnect_delay_max 2 \
               -ss "$pos" -re -i "$STREAM" \
               -vf "scale=$((WIDTH*2)):-2,fps=${FPS}" \
               "$TMPD/g${FRAME_BASE}_f%06d.png" >/dev/null 2>&1 &
    fi
    FFMPEG_PID=$!
    logd "ffmpeg başladı  pid=$FFMPEG_PID  pozisyon=${pos}sn"
}
start_ffmpeg 0

printf '\033[2J'
draw_one() {
    local f="$1"
    local frame
    if [ "$MODE" = iip ]; then
        printf '\033[H\033]1337;File=inline=1;width=%d;height=%d;preserveAspectRatio=0:%s\a' \
               "$WIDTH" "$HEIGHT" "$(base64 -i "$f")"
        return
    fi
    frame=$(chafa --format=symbols --symbols=block+half+quad+space \
                  --size="${WIDTH}x${HEIGHT}" --stretch \
                  -c "$COLORS" --dither none --work 9 \
                  --clear=false --polite=on "$f" 2>/dev/null)
    printf '\033[H%s' "$frame"
}

FIRST_FRAME=1
LASTF=""
DRAWN=0
while kill -0 "$AUDIO_PID" 2>/dev/null; do
    f=$(ls -t "$TMPD"/g*_f*.${EXT} 2>/dev/null | sed -n 2p)
    if [ -n "$f" ] && [ -f "$f" ] && [ "$f" != "$LASTF" ]; then
        [ "$FIRST_FRAME" = 1 ] && { logd "İLK KARE ÇİZİLDİ — video akıyor"; FIRST_FRAME=0; }
        draw_one "$f"
        LASTF="$f"
        DRAWN=$((DRAWN+1))
        [ $((DRAWN % 100)) -eq 0 ] && logd "akış: çizilen=$DRAWN üretilen=$(basename "$f" | grep -o 'f[0-9]*' | tr -d 'f' | sed 's/^0*//')"
        ls -t "$TMPD"/g*_f*.${EXT} 2>/dev/null | tail -n +5 | xargs rm -f 2>/dev/null
    fi
    sleep 0.04
done
logd "BİTTİ: ses motoru kapandı (video sonu veya Ctrl+C)  toplam_kare=$DRAWN"

cleanup
