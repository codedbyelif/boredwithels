#!/bin/bash
# yt-vscode — VS Code terminalinde YouTube izleme + KLAVYE KONTROLÜ
# VS Code terminali sixel/kitty grafik DESTEKLEMEZ ve mpv --vo=tct çökertir.
# Bu yüzden:
#   - SES + SAAT + KONTROL : mpv --no-video (IPC soketi açık) — seek/pause/volume burada
#   - GÖRÜNTÜ              : ffmpeg akışı PNG karelere böler -> chafa renkli blok çizer
#   - SEEK olunca ffmpeg, mpv'nin yeni pozisyonundan yeniden başlatılır (senkron)
#
# Kullanım:  yt-vscode "arama"  |  yt-vscode "https://youtube.com/watch?v=..."
# TUŞLAR:  ← →  10sn geri/ileri   |   ↑ ↓  ses   |   boşluk  duraklat/devam   |   q  çıkış
# Ayarlar (env):  YTV_FPS (5)  YTV_WIDTH (100)
FPS="${YTV_FPS:-5}"
WIDTH="${YTV_WIDTH:-100}"
HEIGHT="${YTV_HEIGHT_ROWS:-$(awk "BEGIN{printf \"%d\", ${WIDTH}/3.5}")}"
MAXH="${YTV_HEIGHT:-480}"

set -uo pipefail
export PATH="$HOME/.local/bin:/opt/homebrew/bin:$PATH"

[ $# -eq 0 ] && { echo "Kullanım: yt-vscode \"arama veya URL\""; exit 1; }
arg="$*"
case "$arg" in http*) page="$arg" ;; *) page="ytsearch1:$arg" ;; esac

TMPD=$(mktemp -d)
SOCK="/tmp/ytv_$$.sock"; rm -f "$SOCK"
AUDIO_PID=""; FFMPEG_PID=""; KEY_PID=""

# --- IPC yardımcısı: ses-mpv'sine komut gönder ---
ipc(){ printf '%s\n' "$1" | nc -U "$SOCK" 2>/dev/null >/dev/null; }
getpos(){ printf '%s\n' '{"command":["get_property","time-pos"]}' \
          | nc -U "$SOCK" 2>/dev/null | grep -o '"data":[0-9.]*' | head -1 | cut -d: -f2; }

cleanup() {
    ipc '{"command":["quit"]}'
    [ -n "$AUDIO_PID" ]  && kill "$AUDIO_PID"  2>/dev/null
    [ -n "$FFMPEG_PID" ] && kill "$FFMPEG_PID" 2>/dev/null
    [ -n "$KEY_PID" ]    && kill "$KEY_PID"    2>/dev/null
    pkill -P $$ ffmpeg 2>/dev/null
    rm -rf "$TMPD"; rm -f "$SOCK"
    stty sane 2>/dev/null
    printf '\033[0m\033[?25h\033[?1049l'; tput cnorm 2>/dev/null
}
trap cleanup EXIT INT TERM

echo "youtube-terminal · codedbyelif"
echo "Çözümleniyor: $arg"
STREAM=$(yt-dlp -f "best[height<=${MAXH}]/best[ext=mp4]/best" -g "$page" 2>/dev/null | head -1)
[ -z "$STREAM" ] && { echo "Çözümlenemedi. Dene:  brew upgrade yt-dlp"; exit 1; }

echo "Başlıyor...  (← → sar | ↑ ↓ ses | boşluk duraklat | q çıkış)"; sleep 1

# Terminale sığan boyut
COLS=$(tput cols 2>/dev/null || echo 80); ROWS=$(tput lines 2>/dev/null || echo 24)
[ "$WIDTH" -gt $((COLS-2)) ] && WIDTH=$((COLS-2))
[ "$HEIGHT" -gt $((ROWS-3)) ] && HEIGHT=$((ROWS-3))

printf '\033[?1049h\033[?25l\033[2J'

# --- SES + SAAT + KONTROL motoru: mpv (görüntüsüz, IPC açık) ---
mpv --no-video --no-config --input-ipc-server="$SOCK" --really-quiet "$STREAM" >/dev/null 2>&1 &
AUDIO_PID=$!
for i in $(seq 1 60); do [ -S "$SOCK" ] && break; sleep 0.1; done

# --- ffmpeg'i belli bir saniyeden (POS) başlatan fonksiyon ---
# Eski ffmpeg'i öldürür, kareleri temizler, yeni sayaçla baştan başlatır.
FRAME_BASE=0   # bu turdaki kare numaralandırma ofseti (her reseek'te artar)
start_ffmpeg() {
    local pos="${1:-0}"
    [ -n "$FFMPEG_PID" ] && kill "$FFMPEG_PID" 2>/dev/null
    pkill -P $$ ffmpeg 2>/dev/null
    rm -f "$TMPD"/f*.png 2>/dev/null
    FRAME_BASE=$((FRAME_BASE+1))
    ffmpeg -loglevel error -ss "$pos" -re -i "$STREAM" \
           -vf "scale=$((WIDTH*2)):-2,fps=${FPS}" \
           "$TMPD/g${FRAME_BASE}_f%06d.png" >/dev/null 2>&1 &
    FFMPEG_PID=$!
}
start_ffmpeg 0

# --- TUŞ DÖNGÜSÜ (arka planda, bloklayan okuma — bash 3.2 uyumlu) ---
( stty -echo -icanon min 1 time 0 2>/dev/null
  while :; do
    IFS= read -rsn1 k 2>/dev/null || break
    if [ "$k" = $'\033' ]; then
      IFS= read -rsn2 -t 1 r 2>/dev/null
      case "$r" in
        '[C') p=$(getpos); ipc "{\"command\":[\"seek\",10,\"relative\",\"exact\"]}";  printf '%s' "$(awk "BEGIN{print $p+10}")" > "$TMPD/.seek" ;;
        '[D') p=$(getpos); ipc "{\"command\":[\"seek\",-10,\"relative\",\"exact\"]}"; printf '%s' "$(awk "BEGIN{x=$p-10; print (x<0?0:x)}")" > "$TMPD/.seek" ;;
        '[A') ipc '{"command":["add","volume",5]}'  ;;
        '[B') ipc '{"command":["add","volume",-5]}' ;;
      esac
    else
      case "$k" in
        ' ') ipc '{"command":["cycle","pause"]}' ;;
        q|Q) break ;;
      esac
    fi
  done
  kill -TERM $$ 2>/dev/null ) &
KEY_PID=$!

# --- ÇİZİM DÖNGÜSÜ (ana) ---
printf '\033[2J'
draw_one() {
    local f="$1"
    local frame
    frame=$(chafa --format=symbols --symbols=block+half+space \
                  --size="${WIDTH}x${HEIGHT}" --stretch \
                  --clear=false --polite=on "$f" 2>/dev/null)
    printf '\033[H%s' "$frame"
}

while kill -0 "$AUDIO_PID" 2>/dev/null; do
    # Seek isteği geldi mi? (tuş döngüsü .seek dosyasına pozisyon yazar)
    if [ -f "$TMPD/.seek" ]; then
        seekpos=$(cat "$TMPD/.seek"); rm -f "$TMPD/.seek"
        start_ffmpeg "$seekpos"
        printf '\033[2J'
    fi
    # En yeni kareyi çiz (sürekli en günceli al, eskileri at)
    f=$(ls -t "$TMPD"/g*_f*.png 2>/dev/null | head -1)
    if [ -n "$f" ] && [ -f "$f" ]; then
        draw_one "$f"
        ls -t "$TMPD"/g*_f*.png 2>/dev/null | tail -n +3 | xargs rm -f 2>/dev/null
    fi
    sleep 0.04
done

cleanup
